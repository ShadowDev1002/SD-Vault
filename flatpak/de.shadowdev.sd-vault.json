{
  "app-id": "de.shadowdev.sd-vault",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable", "org.freedesktop.Sdk.Extension.node20"],
  "command": "sd-vault",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--talk-name=org.freedesktop.secrets"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node20/bin",
    "env": {
      "CARGO_HOME": "/run/build/sd-vault/cargo",
      "npm_config_cache": "/run/build/sd-vault/npm-cache",
      "XDG_DATA_HOME": "/run/build/sd-vault/xdg-data"
    }
  },
  "modules": [
    {
      "name": "pnpm",
      "buildsystem": "simple",
      "build-commands": [
        "npm install -g pnpm"
      ],
      "sources": []
    },
    {
      "name": "sd-vault",
      "buildsystem": "simple",
      "build-options": {
        "build-args": ["--share=network"]
      },
      "build-commands": [
        "pnpm install",
        "pnpm build",
        "cargo build --release --manifest-path src-tauri/Cargo.toml",
        "install -Dm755 src-tauri/target/release/sd-vault /app/bin/sd-vault",
        "install -Dm644 src-tauri/icons/128x128.png /app/share/icons/hicolor/128x128/apps/de.shadowdev.sd-vault.png",
        "install -Dm644 src-tauri/icons/32x32.png /app/share/icons/hicolor/32x32/apps/de.shadowdev.sd-vault.png",
        "install -Dm644 flatpak/de.shadowdev.sd-vault.desktop /app/share/applications/de.shadowdev.sd-vault.desktop",
        "install -Dm644 flatpak/de.shadowdev.sd-vault.metainfo.xml /app/share/metainfo/de.shadowdev.sd-vault.metainfo.xml"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
